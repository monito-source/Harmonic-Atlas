{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "fondo",
          "name": "Fondo",
          "color": "#ecf0f1"
        },
        {
          "slug": "texto",
          "name": "Texto",
          "color": "#2c3e50"
        },
        {
          "slug": "azul-principal",
          "name": "Azul principal",
          "color": "#1e3a8a"
        },
        {
          "slug": "azul-hover",
          "name": "Azul hover",
          "color": "#1e40af"
        },
        {
          "slug": "oscuro",
          "name": "Oscuro",
          "color": "#1f2937"
        },
        {
          "slug": "blanco",
          "name": "Blanco",
          "color": "#ffffff"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "'Libre Baskerville', serif",
          "name": "Libre Baskerville",
          "slug": "libre-baskerville"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.9rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1.05rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.5rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "2.4rem",
          "name": "XL"
        }
      ],
      "lineHeight": true,
      "fluid": true
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "XS",
          "size": "0.5rem"
        },
        {
          "slug": "30",
          "name": "S",
          "size": "0.75rem"
        },
        {
          "slug": "40",
          "name": "M",
          "size": "1rem"
        },
        {
          "slug": "50",
          "name": "L",
          "size": "1.5rem"
        },
        {
          "slug": "60",
          "name": "XL",
          "size": "2.25rem"
        },
        {
          "slug": "70",
          "name": "2XL",
          "size": "3rem"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "10px"
        },
        "color": {
          "background": "var:preset|color|azul-principal",
          "text": "var:preset|color|blanco"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "1rem"
        }
      },
      "core/site-title": {
        "typography": {
          "fontSize": "1.9rem",
          "fontWeight": "700"
        }
      }
    },
    "custom": {
      "layout": {
        "sectionPadding": "clamp(2rem, 5vw, 3rem)",
        "contentPadding": "clamp(0.95rem, 4vw, 2.5rem)"
      },
      "radius": {
        "card": "24px",
        "hero": "28px"
      },
      "shadow": {
        "header": "0 18px 40px rgba(15, 23, 42, 0.16)",
        "card": "0 18px 45px rgba(30, 58, 138, 0.12)",
        "hero": "0 18px 45px rgba(15, 23, 42, 0.18)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|fondo",
      "text": "var:preset|color|texto"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|libre-baskerville",
      "fontSize": "1.05rem",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|oscuro"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|azul-principal"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|azul-hover"
          }
        }
      },
      "button": {
        "border": {
          "radius": "10px"
        },
        "color": {
          "background": "var:preset|color|azul-principal",
          "text": "var:preset|color|blanco"
        },
        "spacing": {
          "padding": {
            "top": "0.65rem",
            "right": "1rem",
            "bottom": "0.65rem",
            "left": "1rem"
          }
        }
      }
    },
    "blocks": {
      "core/post-content": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "2rem"
        }
      },
      "core/button": {
        "border": {
          "radius": "var(--wp--preset--spacing--20)"
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|40"
          }
        }
      }
    },
    "spacing": {
      "blockGap": "var:preset|spacing|50"
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "header-musica-hijas",
      "title": "Header música (hijas)",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "presskit",
      "title": "Press Kit",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "proyectos-musica",
      "title": "Proyectos (Música)",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "proyectos-tecnologias",
      "title": "Proyectos (Tecnologías y web)",
      "postTypes": [
        "page"
      ]
    }
  ]
}
