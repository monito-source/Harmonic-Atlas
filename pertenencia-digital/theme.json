{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "fondo",
          "name": "Fondo",
          "color": "#ecf0f1"
        },
        {
          "slug": "texto",
          "name": "Texto",
          "color": "#2c3e50"
        },
        {
          "slug": "azul-principal",
          "name": "Azul principal",
          "color": "#1e3a8a"
        },
        {
          "slug": "azul-hover",
          "name": "Azul hover",
          "color": "#1e40af"
        },
        {
          "slug": "oscuro",
          "name": "Oscuro",
          "color": "#1f2937"
        },
        {
          "slug": "blanco",
          "name": "Blanco",
          "color": "#ffffff"
        },
        {
          "slug": "texto-suave",
          "name": "Texto suave",
          "color": "#64748b"
        },
        {
          "slug": "borde-suave",
          "name": "Borde suave",
          "color": "#cbd5e1"
        },
        {
          "slug": "resalte-header",
          "name": "Resalte header",
          "color": "#8fd3ff"
        },
        {
          "slug": "exito",
          "name": "Éxito",
          "color": "#166534"
        },
        {
          "slug": "error",
          "name": "Error",
          "color": "#991b1b"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "'Libre Baskerville', serif",
          "name": "Libre Baskerville",
          "slug": "libre-baskerville"
        }
      ],
      "fontSizes": [
        {
          "slug": "x-small",
          "size": "0.85rem",
          "name": "XS"
        },
        {
          "slug": "small",
          "size": "0.9rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1.05rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.5rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "2.4rem",
          "name": "XL"
        }
      ],
      "lineHeight": true,
      "fluid": true
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "XS",
          "size": "0.5rem"
        },
        {
          "slug": "30",
          "name": "S",
          "size": "0.75rem"
        },
        {
          "slug": "40",
          "name": "M",
          "size": "1rem"
        },
        {
          "slug": "50",
          "name": "L",
          "size": "1.5rem"
        },
        {
          "slug": "55",
          "name": "L+",
          "size": "1.75rem"
        },
        {
          "slug": "60",
          "name": "XL",
          "size": "2.25rem"
        },
        {
          "slug": "65",
          "name": "XL+",
          "size": "2.5rem"
        },
        {
          "slug": "70",
          "name": "2XL",
          "size": "3rem"
        },
        {
          "slug": "80",
          "name": "3XL",
          "size": "4rem"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--button)"
        },
        "color": {
          "background": "var:preset|color|azul-principal",
          "text": "var:preset|color|blanco"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "1rem"
        }
      },
      "core/site-title": {
        "typography": {
          "fontSize": "1.9rem",
          "fontWeight": "700"
        }
      }
    },
    "custom": {
      "layout": {
        "sectionPadding": "clamp(2rem, 5vw, 3rem)",
        "contentPadding": "clamp(0.95rem, 4vw, 2.5rem)"
      },
      "radius": {
        "button": "10px",
        "card": "24px",
        "hero": "28px",
        "pill": "999px"
      },
      "shadow": {
        "header": "0 18px 40px rgba(15, 23, 42, 0.16)",
        "card": "0 18px 45px rgba(30, 58, 138, 0.12)",
        "hero": "0 18px 45px rgba(15, 23, 42, 0.18)"
      },
      "auth": {
        "introText": "var(--wp--preset--color--blanco)",
        "introBackground": "linear-gradient(140deg, var(--wp--preset--color--oscuro), var(--wp--preset--color--azul-principal))",
        "introGlow": "color-mix(in srgb, var(--wp--preset--color--resalte-header) 30%, transparent)",
        "cardBackground": "var(--wp--preset--color--blanco)",
        "cardText": "var(--wp--preset--color--texto)",
        "cardBorder": "color-mix(in srgb, var(--wp--preset--color--oscuro) 12%, transparent)",
        "fieldBackground": "var(--wp--preset--color--blanco)",
        "fieldText": "var(--wp--preset--color--texto)",
        "fieldBorder": "color-mix(in srgb, var(--wp--preset--color--oscuro) 15%, transparent)",
        "link": "var(--wp--preset--color--azul-principal)",
        "linkHover": "var(--wp--preset--color--azul-hover)"
      },
      "header": {
        "account": {
          "triggerBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 12%, transparent)",
          "triggerText": "var(--wp--preset--color--blanco)",
          "triggerBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 26%, transparent)",
          "triggerHoverBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 18%, transparent)",
          "triggerHoverBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 40%, transparent)",
          "panelBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 96%, transparent)",
          "panelText": "var(--wp--preset--color--texto)",
          "panelBorder": "color-mix(in srgb, var(--wp--preset--color--oscuro) 10%, transparent)",
          "panelHoverBackground": "color-mix(in srgb, var(--wp--preset--color--azul-principal) 10%, transparent)"
        },
        "navigation": {
          "triggerBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 12%, transparent)",
          "triggerText": "var(--wp--preset--color--blanco)",
          "triggerBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 26%, transparent)",
          "triggerHoverBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 18%, transparent)",
          "triggerHoverBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 40%, transparent)",
          "panelBackground": "color-mix(in srgb, var(--wp--preset--color--oscuro) 88%, rgba(255,255,255,0.08))",
          "panelText": "var(--wp--preset--color--blanco)",
          "panelBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 22%, transparent)",
          "itemBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 5%, transparent)",
          "itemBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 14%, transparent)",
          "itemHoverBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 10%, transparent)",
          "itemHoverBorder": "color-mix(in srgb, var(--wp--preset--color--resalte-header) 30%, transparent)",
          "itemHoverText": "var(--wp--preset--color--resalte-header)"
        },
        "subnavigation": {
          "text": "var(--wp--preset--color--blanco)",
          "itemBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 4%, transparent)",
          "itemBorder": "color-mix(in srgb, var(--wp--preset--color--blanco) 16%, transparent)",
          "itemHoverBackground": "color-mix(in srgb, var(--wp--preset--color--blanco) 8%, transparent)",
          "itemHoverBorder": "color-mix(in srgb, var(--wp--preset--color--resalte-header) 20%, transparent)",
          "itemCurrentBackground": "color-mix(in srgb, var(--wp--preset--color--resalte-header) 16%, transparent)",
          "itemCurrentBorder": "color-mix(in srgb, var(--wp--preset--color--resalte-header) 44%, transparent)",
          "itemCurrentText": "var(--wp--preset--color--blanco)"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|fondo",
      "text": "var:preset|color|texto"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|libre-baskerville",
      "fontSize": "1.05rem",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|oscuro"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|azul-principal"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|azul-hover"
          }
        }
      },
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--button)"
        },
        "color": {
          "background": "var:preset|color|azul-principal",
          "text": "var:preset|color|blanco"
        },
        "spacing": {
          "padding": {
            "top": "0.65rem",
            "right": "1rem",
            "bottom": "0.65rem",
            "left": "1rem"
          }
        }
      }
    },
    "blocks": {
      "core/post-content": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "2rem"
        }
      },
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--button)"
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|40"
          }
        }
      }
    },
    "spacing": {
      "blockGap": "var:preset|spacing|50"
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "header-musica-hijas",
      "title": "Header música (hijas)",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "acceso",
      "title": "Acceso",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "inicio",
      "title": "Inicio / Landing",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "presskit",
      "title": "Press Kit",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "mi-pertenencia",
      "title": "Mi pertenencia",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "proyectos-musica",
      "title": "Proyectos (Música)",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "proyectos-tecnologias",
      "title": "Proyectos (Tecnologías y web)",
      "postTypes": [
        "page"
      ]
    }
  ]
}
