{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-song-study/current-membership",
  "version": "2.1.1",
  "title": "Current Membership",
  "category": "widgets",
  "icon": "admin-users",
  "description": "Displays a frontend area where the logged-in user can edit their presskit and review their projects.",
  "textdomain": "wp-song-study-blocks",
  "keywords": ["membership", "presskit", "profile", "projects"],
  "attributes": {
    "targetUserId": {
      "type": "number",
      "default": 0
    },
    "showProjects": {
      "type": "boolean",
      "default": true
    },
    "showPreview": {
      "type": "boolean",
      "default": true
    },
    "showAdminLink": {
      "type": "boolean",
      "default": true
    },
    "loginMessage": {
      "type": "string",
      "default": "Inicia sesión para gestionar tu presskit y revisar tus proyectos."
    },
    "layoutWidth": {
      "type": "string",
      "default": "immersive"
    },
    "editorMinHeight": {
      "type": "number",
      "default": 720
    },
    "shellTextColor": {
      "type": "string",
      "default": ""
    },
    "headerBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "headerTextColor": {
      "type": "string",
      "default": ""
    },
    "panelBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "panelTextColor": {
      "type": "string",
      "default": ""
    },
    "panelBorderColor": {
      "type": "string",
      "default": ""
    },
    "fieldBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "fieldTextColor": {
      "type": "string",
      "default": ""
    },
    "linkColor": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "border": {
      "radius": true,
      "color": true
    }
  },
  "editorScript": "file:./index.js"
}
