{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-song-study/interface",
  "version": "0.1.0",
  "title": "Song Study Interface",
  "category": "widgets",
  "icon": "playlist-audio",
  "description": "Interactive song study browser, reading view, and editor powered by the WP Song Study REST API.",
  "textdomain": "wp-song-study-blocks",
  "keywords": ["song", "study", "reader", "music"],
  "attributes": {
    "compactMode": {
      "type": "boolean",
      "default": false
    },
    "panelBackgroundColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "panelBackgroundOpacity": {
      "type": "number",
      "default": 80
    },
    "textColor": {
      "type": "string",
      "default": "#4b5563"
    },
    "headingColor": {
      "type": "string",
      "default": "#1f2937"
    },
    "buttonColor": {
      "type": "string",
      "default": "#1e3a8a"
    },
    "buttonTextColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "buttonEmphasisColor": {
      "type": "string",
      "default": "#e7ecf6"
    },
    "buttonEmphasisTextColor": {
      "type": "string",
      "default": "#1e3a8a"
    },
    "buttonDangerColor": {
      "type": "string",
      "default": "#7f1d1d"
    },
    "buttonDangerTextColor": {
      "type": "string",
      "default": "#ffffff"
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "editorScript": "file:./index.js"
}
